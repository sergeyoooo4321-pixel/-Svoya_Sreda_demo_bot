# App
APP_ENV=dev
APP_NAME=svoya-sreda-bot
LOG_LEVEL=INFO
BOT_MODE=polling

# Telegram
TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=123456789,987654321

# Webhook mode, optional
WEBHOOK_BASE_URL=https://example.com
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET_TOKEN=change_me
WEB_SERVER_HOST=0.0.0.0
WEB_SERVER_PORT=8080

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_API_KEY=
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_TEMPERATURE=0.3
OLLAMA_USE_STRUCTURED_OUTPUT=true
# Окно контекста модели для агентного режима (tool calling + история диалога)
OLLAMA_NUM_CTX=8192

# Bitrix24
BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/xxxxxx/
BITRIX_USE_UNIVERSAL_CRM=true
BITRIX_TIMEOUT_SECONDS=30

# Bitrix24 CRM entity type ids for universal crm.item.* methods
BITRIX_ENTITY_TYPE_ID_LEAD=1
BITRIX_ENTITY_TYPE_ID_DEAL=2

# Lead stages/statuses. Fill actual Bitrix24 status IDs after CRM setup.
BITRIX_LEAD_STAGE_NEW=NEW
BITRIX_LEAD_STAGE_CONSULTATION=CONSULTATION
BITRIX_LEAD_STAGE_WAITING=WAITING
BITRIX_LEAD_STAGE_ORDER_CREATED=ORDER_CREATED
BITRIX_LEAD_STAGE_REFUSED=JUNK

# Deal stages. Fill actual values if deals are used.
BITRIX_DEAL_STAGE_NEW=NEW
BITRIX_DEAL_STAGE_PREPAYMENT=PREPAYMENT
BITRIX_DEAL_STAGE_DELIVERY=DELIVERY
BITRIX_DEAL_STAGE_WON=WON
BITRIX_DEAL_STAGE_LOSE=LOSE

# Bitrix24 custom fields for Leads. Use real UF_CRM_* codes after fields are created.
BITRIX_LEAD_FIELD_PRODUCT=UF_CRM_INTEREST_PRODUCT
BITRIX_LEAD_FIELD_CITY=UF_CRM_DELIVERY_CITY
BITRIX_LEAD_FIELD_BOT_COMMENT=UF_CRM_BOT_COMMENT

# Bitrix24 custom fields for Deals. Use real UF_CRM_* codes after fields are created.
BITRIX_DEAL_FIELD_COLOR=UF_CRM_FURNITURE_COLOR
BITRIX_DEAL_FIELD_DELIVERY_TYPE=UF_CRM_DELIVERY_TYPE
BITRIX_DEAL_FIELD_ASSEMBLY=UF_CRM_NEED_ASSEMBLY
BITRIX_DEAL_FIELD_DELIVERY_DATE=UF_CRM_ESTIMATED_DELIVERY_DATE

# Local storage
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
HISTORY_LIMIT=10
SESSION_TTL_HOURS=24

# ---------------- Agent / Memory / Knowledge ----------------
# Память диалога
MEMORY_LAST_MESSAGES=50
MEMORY_SUMMARY_AFTER_MESSAGES=30

# Защита от бесконечного tool loop
AGENT_MAX_TOOL_CALLS=5
AGENT_DEBUG=false

# Bitrix24 Knowledge Base (LEGACY — активна только при CRM_MODE=bitrix)
BITRIX24_BASE_URL=
BITRIX24_KB_ENTITY_TYPE_ID=0
BITRIX24_PRODUCTS_ENTITY_TYPE_ID=0

# ---------------- Svoya CRM (локальный аналог Bitrix24, т.md §5) ----------------
# По умолчанию используется локальная CRM. Bitrix24 больше не требуется.
CRM_MODE=local
# Отдельная БД локальной CRM (лиды, сделки, товары, знания, активности, память агента)
SVOYA_CRM_DATABASE_URL=file:./data/svoya_crm.db

# HTTP API локальной CRM (для сайта и внешних интеграций)
LOCAL_CRM_BASE_URL=http://localhost:3000/api/local-crm
LOCAL_CRM_API_KEY=demo-local-crm-secret

# Админка Svoya CRM (/admin) — basic-auth
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
ADMIN_HOST=0.0.0.0
ADMIN_PORT=3000

SITE_URL=http://localhost:3000
FORM_SECRET=demo-form-secret
WEBHOOK_SECRET=demo-webhook-secret

# Память агента — новые имена из ТЗ (старые MEMORY_* тоже принимаются)
AGENT_MEMORY_LAST_MESSAGES=50
AGENT_MEMORY_SUMMARY_AFTER_MESSAGES=30
